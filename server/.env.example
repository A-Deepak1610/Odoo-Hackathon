PORT=5000
NODE_ENV=development
LOG_LEVEL=debug

# Update the database credentials below to match your local PostgreSQL setup
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/assertflow?schema=public"

# Secrets for token generation (use cryptographically secure strings in production)
JWT_SECRET="your_jwt_access_secret_key"
JWT_REFRESH_SECRET="your_jwt_refresh_secret_key"
